{
  "name": "ipl-fantasy-ios-e2e",
  "version": "1.0.0",
  "description": "Appium E2E tests for IPL Fantasy Pro iOS app",
  "main": "appium.test.js",
  "scripts": {
    "test": "wdio run wdio.conf.js",
    "test:ios": "PLATFORM=ios wdio run wdio.conf.js",
    "test:android": "PLATFORM=android wdio run wdio.conf.js",
    "test:simulator": "TEST_ENV=ios-simulator wdio run wdio.conf.js",
    "test:headed": "wdio run wdio.conf.js --headed",
    "test:debug": "wdio run wdio.conf.js --debug",
    "test:spec": "wdio run wdio.conf.js --spec=appium.test.js"
  },
  "keywords": [
    "appium",
    "ios",
    "e2e",
    "testing",
    "automation"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "webdriverio": "^8.16.0"
  },
  "devDependencies": {
    "@wdio/cli": "^8.16.0",
    "@wdio/jasmine-framework": "^8.16.0",
    "@wdio/local-runner": "^8.16.0",
    "@wdio/spec-reporter": "^8.16.0",
    "jasmine": "^5.1.0"
  }
}
